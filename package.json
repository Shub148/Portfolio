{
  "name": "shubham-yadav-portfolio",
  "version": "1.0.0",
  "description": "Shubham Yadav's Portfolio Website - Web Developer Portfolio",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install-client": "cd client && npm install",
    "heroku-postbuild": "npm run install-client && npm run build"
  },
  "keywords": [
    "portfolio",
    "web developer",
    "react",
    "nodejs"
  ],
  "author": "Shubham Yadav",
  "license": "MIT",
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "nodemailer": "^6.10.1",
    "twilio": "^4.23.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
